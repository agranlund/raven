	(text "Differences from standalone CKBD upgrade:\n\n- PWR_SW moved from P0.3 to P0.0\n\n- FAN1_PWM added on P2.5\n- FAN1_RGB added on P3.4\n- FAN1_PWR removed from P3.5\n\n- PS2M removed from P3.2, P3.3\n- PS2K removed from P3.6, P3.7\n\n- J0UP added on P3.2 (for irq)\n- J0LEFT added on P3.3 (for irq)\n"
		(exclude_from_sim no)
		(at 335.915 75.565 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "2b3340ec-50a4-4e87-9501-3b7c4e972fd8")
	)
